# Copy this file to `.env` and fill in real values. Never commit `.env`.
OPENAI_API_KEY=sk-your-key-here

# Where to dump the generated OpenAPI schema at startup. Defaults to
# `./openapi.json` (project root) if unset. Point this at a sibling dir
# (e.g. ../frontend/openapi.json) if your frontend dev workflow expects it there.
OPENAPI_DUMP_PATH=openapi.json

# HS256 secret shared with nestjs-meetworld-backend so the NestJS-issued
# access tokens validate here. Use the same value as
# nestjs-meetworld-backend/.env `JWT_SECRET`. In production (GCP Cloud Run),
# point both services at the same Secret Manager secret.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256