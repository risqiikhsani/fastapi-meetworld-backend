# Copy this file to `.env` and fill in real values. Never commit `.env`.
OPENAI_API_KEY=sk-your-key-here

# Where to dump the generated OpenAPI schema at startup. Defaults to
# `./openapi.json` (project root) if unset. Point this at a sibling dir
# (e.g. ../frontend/openapi.json) if your frontend dev workflow expects it there.
OPENAPI_DUMP_PATH=openapi.json