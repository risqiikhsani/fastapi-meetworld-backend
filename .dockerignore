# ----- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# ----- Local config / secrets ----------------------------------------------
# .env files contain OPENAI_API_KEY — never bake into the image.
.env
.env.*

# ----- VCS / IDE / Claude ---------------------------------------------------
.git/
.gitignore
.gitattributes
.agents/
.claude/
.cursor/
.vscode/
.idea/
*.swp
*.swo

# ----- Generated artifacts --------------------------------------------------
# Regenerated by the lifespan in app/main.py on every startup; not needed
# in the image itself.
openapi.json

# ----- Docs (not needed at runtime) -----------------------------------------
*.md
LICENSE

# ----- OS junk --------------------------------------------------------------
.DS_Store
Thumbs.db

# ----- Defensive: any leftover Node.js traces -------------------------------
# Repo is Python-only; ignore in case any of these slip into a future commit.
node_modules/
package.json
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.yarn/